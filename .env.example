# AgentGate Configuration
# Copy this to .env and fill in your values

# Mode: "mock" (default, no AWS needed) or "real" (uses AWS IAM)
AGENTGATE_MODE=mock

# AWS credentials (required for real mode)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_ACCOUNT_ID=682033501708

# API key mapping (JSON) — maps API keys to IAM user ARNs
# Update the account ID to match your AWS account
AGENTGATE_API_KEYS={"alice-key": {"user_arn": "arn:aws:iam::682033501708:user/agentgate-alice", "agent_id": "agent-alice"}, "bob-key": {"user_arn": "arn:aws:iam::682033501708:user/agentgate-bob", "agent_id": "agent-bob"}}

# Agent role ARN (for privilege creep analysis)
AGENTGATE_AGENT_ROLE_ARN=arn:aws:iam::682033501708:role/agentgate-agent-role

# Audit database path (defaults to /tmp/agentgate_audit.db)
# AGENTGATE_AUDIT_DB=/data/audit.db
